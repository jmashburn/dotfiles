#!/bin/bash
#
# dot -- dotfiles management
#
# Run with no args to refresh symlinks and pull latest changes.
#

set -e

parentDirectory="$(cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

displayUsageAndExit() {
    echo "dot -- dotfiles management"
    echo ""
    echo "Usage: dot [options]"
    echo ""
    echo "Options:"
    echo "  -e, --edit       Open dotfiles directory for editing"
    echo "  -t, --tools      Run tool installers (Go, AWS CLI, etc.)"
    echo "  -h, --help       Show this message and exit"
    echo ""
    echo "Running dot with no options will:"
    echo "  1. Pull latest changes from git"
    echo "  2. Refresh all symlinks (skipping existing)"
    exit
}

run_tools=false

while test $# -gt 0; do
    case "$1" in
        "-h"|"--help")
            displayUsageAndExit
            ;;
        "-e"|"--edit")
            exec "$EDITOR" "$dotfilesDirectory"
            ;;
        "-t"|"--tools")
            run_tools=true
            ;;
        *)
            echo "Invalid option: $1"
            displayUsageAndExit
            ;;
    esac
    shift
done

# Pull latest
echo "> Pulling latest changes"
git -C "$dotfilesDirectory" pull --rebase --quiet

# Refresh symlinks (skip existing)
echo "> Refreshing symlinks"
"$dotfilesDirectory/script/bootstrap" -S

if [ "$run_tools" = "true" ]; then
    echo "> Running tool installers"
    "$dotfilesDirectory/script/install-tools"
fi

echo ""
echo "  Done."
