{
  "env": {},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cwd-changed.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-changed.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "migrate-openstack-to-openshift@redhat-itup-skills": true
  },
  "extraKnownMarketplaces": {
    "redhat-itup-skills": {
      "source": {
        "source": "git",
        "url": "https://gitlab.cee.redhat.com/it-cloud-openshift/openstack-rdu2-exit/ai-automation-skills.git"
      },
      "autoUpdate": true
    }
  },
  "sandbox": {
    "failIfUnavailable": false
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "askUserQuestionTimeout": "60s",
  "autoDreamEnabled": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "vim": {
    "enabled": true
  },
  "mcpServers": {
    "marvin": {
      "command": "node",
      "args": [
        "/Volumes/Code/marvin-mcp/dist/index.js"
      ],
      "env": {
        "MARVIN_API_URL": "http://localhost:8080",
        "MARVIN_SITE_CLIENT_TOKEN": "marvin_sk_7AKGwi9xxIrieRo28RyQUxBjy5XRhNgOSjpHsPsqEkw",
        "MARVIN_WORKSPACE_SLUG": "mash-burn-co"
      }
    }
  }
}
