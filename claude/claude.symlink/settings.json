{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "vim": {
    "enabled": true
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(curl:*)",
      "Bash(sleep:*)",
      "Bash(oc:*)",
      "Bash(mpp:*)",
      "Bash(sqlite3:*)",
      "Bash(chmod +x:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)"
    ]
  },
  "sandbox": {
    "failIfUnavailable": false
  },
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "showClearContextOnPlanAccept": true,
  "hooks": {
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cwd-changed.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/file-changed.sh"
          }
        ]
      }
    ]
  }
}
