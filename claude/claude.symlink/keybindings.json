{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Chat",
      "bindings": {
        "ctrl+x ctrl+k": "chat:killAgents",
        "ctrl+shift+f": "chat:fastMode",
        "ctrl+x ctrl+e": "chat:externalEditor"
      }
    }
  ]
}
