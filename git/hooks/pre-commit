#!/bin/sh
# Block debug statements left in staged source files
debug_patterns='console\.log|debugger|binding\.pry|byebug|var_dump\(|print_r\('
matches=$(git diff --cached --name-only \
  | grep -E '\.(js|jsx|ts|tsx|mjs|cjs|rb|py|php|go|java|kt|swift|cs)$' \
  | xargs grep -lE "$debug_patterns" 2>/dev/null)
if [ -n "$matches" ]; then
  echo ""
  echo "  ❌ Debug statements found in staged files:"
  echo "$matches" | sed 's/^/     /'
  echo ""
  echo "  Remove them or use 'git commit --no-verify' to bypass."
  echo ""
  exit 1
fi

# Block large files (>500KB)
git diff --cached --name-only | while IFS= read -r f; do
  size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
  if [ "$size" -gt 512000 ]; then
    echo ""
    echo "  ❌ Large file staged: $f ($(( size / 1024 ))KB)"
    echo "  Add it to .gitignore or use Git LFS."
    echo ""
    exit 1
  fi
done
