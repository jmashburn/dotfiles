#!/bin/sh
# Block direct push to main/master/develop
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$branch" in
  main|master|develop)
    echo ""
    echo "  ❌ Direct push to '$branch' is blocked."
    echo "  Open a pull request instead, or use 'git push --no-verify' to bypass."
    echo ""
    exit 1
    ;;
esac

# Block pushing WIP commits
wip=$(git log @{u}..HEAD --oneline 2>/dev/null | grep "^[a-f0-9]* WIP")
if [ -n "$wip" ]; then
  echo ""
  echo "  ❌ WIP commits detected — squash or amend before pushing:"
  echo "$wip" | sed 's/^/     /'
  echo ""
  exit 1
fi
