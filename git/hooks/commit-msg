#!/bin/sh
# Strip AI co-authorship trailers from commit messages (cross-platform)
perl -i -ne 'print unless /^Co-Authored-By:.*[Cc]laude/' "$1"

# Enforce Conventional Commits format
# Allow: feat|fix|chore|docs|refactor|test|style|perf|ci|build|revert
# with optional scope: feat(api): ...
# Also allow merge commits and WIP commits to pass through
msg=$(head -1 "$1")

# Skip merge commits, revert commits auto-generated by git, and WIP
case "$msg" in
  Merge\ *|Revert\ \"*|WIP*) exit 0 ;;
esac

pattern='^(feat|fix|chore|docs|refactor|test|style|perf|ci|build|revert)(\([a-z0-9._-]+\))?!?: .+'

if ! echo "$msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ❌ Commit message must follow Conventional Commits format:"
  echo ""
  echo "     type(scope): description"
  echo ""
  echo "  Types: feat  fix  chore  docs  refactor  test  style  perf  ci  build  revert"
  echo "  Examples:"
  echo "     feat: add user authentication"
  echo "     fix(api): handle null response from endpoint"
  echo "     chore!: drop support for Node 14"
  echo ""
  echo "  Your message: \"$msg\""
  echo ""
  exit 1
fi
